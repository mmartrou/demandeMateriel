# Variables d'environnement

# Base de données PostgreSQL (obligatoire en production)
# Sur Railway : défini automatiquement si vous ajoutez un service PostgreSQL
# Sur VPS OVH : à renseigner manuellement
DATABASE_URL=postgresql://user:password@host:5432/database

# Configuration Flask
FLASK_ENV=production
PORT=8080
FLASK_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
SESSION_COOKIE_SECURE=true
MAX_UPLOAD_MB=10

# Auth Google (obligatoire)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_WORKSPACE_DOMAIN=lfmadrid.org

# Admin unique (toi)
ADMIN_EMAIL=guillaume.martrou@lfmadrid.org

# Mapping email Google -> enseignant (nom EXACT de la table teachers)
# Format JSON sur une seule ligne
# Exemple:
# {"bonfand@etablissement.fr":"Bonfand","martrou@etablissement.fr":"Martrou"}
TEACHER_EMAIL_MAP={"vincent.bats@lfmadrid.org":"Bats","eric.bonfand@lfmadrid.org":"Bonfand","tom.calazel@lfmadrid.org":"Calazel","anne.carpentier@lfmadrid.org":"Carpentier","esther.courreges@lfmadrid.org":"Courrèges","david.diazdelpino@lfmadrid.org":"Diaz Del Pino","jose.hidalgo@lfmadrid.org":"Hidalgo","hugues.landspurg@lfmadrid.org":"Landspurg","christian.lefranc@lfmadrid.org":"Lefranc","guillaume.martrou@lfmadrid.org":"Martrou","francky.masnou@lfmadrid.org":"Masnou","emmanuel.mazy@lfmadrid.org":"Mazy","julien.moreau@lfmadrid.org":"Moreau","serge.paupy@lfmadrid.org":"Paupy","valerie.potier@lfmadrid.org":"Potier","nils.richard@lfmadrid.org":"Richard","guillaume.vernudachi@lfmadrid.org":"Vernudachi","silvia.vila@lfmadrid.org":"Vila Gisbert"}